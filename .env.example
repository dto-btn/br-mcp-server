# Database Configuration
BITS_DB_SERVER=your-db-server.domain
BITS_DB_USERNAME=your-username
BITS_DB_PWD=your-password
BITS_DB_DATABASE=your-database-name

# Server Configuration
HOST=0.0.0.0
PORT=8000
MCP_SERVER_URL=http://127.0.0.1:8000/mcp

# Azure OpenAI Configuration (for client)
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_VERSION=2024-05-01-preview

# Authentication (Optional/Future use)
# CLIENT_ID=your-client-id
# CLIENT_SECRET=your-client-secret
# REDIRECT_URI=http://localhost:8000/callback

# CORS Settings
# If not set, it defaults to http://localhost, http://127.0.0.1
CORS_ALLOW_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
CORS_ALLOW_CREDENTIALS=false
